{
  "name": "@callsitehq/runtime",
  "version": "0.2.0",
  "description": "Runtime dispatch engine for Callsite capabilities.",
  "keywords": [
    "agents",
    "capabilities",
    "mcp",
    "openapi",
    "runtime",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/callsitehq/callsite/tree/main/packages/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callsitehq/callsite.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/callsitehq/callsite/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "default": "./dist/express.js"
    },
    "./aws-lambda": {
      "types": "./dist/aws-lambda.d.ts",
      "default": "./dist/aws-lambda.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "sideEffects": false,
  "dependencies": {
    "@callsitehq/core": "workspace:*",
    "@callsitehq/emit": "workspace:*",
    "@types/aws-lambda": "^8.10.162",
    "@types/express": "^5.0.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  }
}
