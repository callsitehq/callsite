{
  "name": "orders",
  "version": "0.1.0",
  "tools": [
    {
      "name": "orders.find",
      "description": "Search a customer's orders by email and optional status. Use this before acting on a specific order, such as before issuing a refund.",
      "inputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
            "description": "Customer email address to search."
          },
          "status": {
            "description": "Optional order status filter.",
            "type": "string",
            "enum": [
              "paid",
              "shipped",
              "refunded"
            ]
          },
          "limit": {
            "default": 10,
            "type": "integer",
            "minimum": 1,
            "maximum": 25
          }
        },
        "required": [
          "email"
        ]
      },
      "outputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "orders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "orderId": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "paid",
                    "shipped",
                    "refunded"
                  ]
                },
                "totalCents": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "refundedCents": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "orderId",
                "status",
                "totalCents",
                "refundedCents"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "orders"
        ],
        "additionalProperties": false
      },
      "annotations": {
        "destructiveHint": false
      }
    },
    {
      "name": "orders.refund",
      "description": "Refund a customer's paid order, either fully or partially. Use when the customer has selected a specific paid order and wants money returned. Do not use to cancel unpaid orders.",
      "inputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "description": "The paid order to refund, e.g. ord_1001."
          },
          "amountCents": {
            "description": "Partial amount in cents. Omit to refund the remaining order total.",
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "reason": {
            "description": "Customer-facing reason for the refund.",
            "type": "string"
          }
        },
        "required": [
          "orderId"
        ]
      },
      "outputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "refundId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "refunded",
              "pending"
            ]
          },
          "refundedCents": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "refundId",
          "status",
          "refundedCents"
        ],
        "additionalProperties": false
      },
      "_meta": {
        "callsitehq.com/errors": [
          {
            "code": "unauthorized",
            "intent": "A signed-in support subject is required to refund orders."
          },
          {
            "code": "forbidden",
            "intent": "Refunding orders is disabled for the current support subject."
          },
          {
            "code": "not_found",
            "intent": "No paid order exists for the provided orderId."
          },
          {
            "code": "conflict",
            "intent": "The order is not in a refundable state, is already refunded, or the requested refund exceeds the refundable amount."
          }
        ]
      },
      "annotations": {
        "destructiveHint": true
      }
    }
  ]
}
